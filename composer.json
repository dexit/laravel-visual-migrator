{
    "name": "ekosuprianto96/laravel-visual-migrator",
    "description": "Visual Schema Designer for Laravel Migrations (powered by Mongo Diagram)",
    "version": "2.6.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Eko Suprianto",
            "email": "ekosuprianto96@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ekosuprianto96\\VisualMigrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ekosuprianto96\\VisualMigrator\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ekosuprianto96\\VisualMigrator\\VisualMigratorServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ]
    }
}