{\n    "name": "dexit/laravel-visual-migrator",\n    "description": "A standalone Laravel application for visual database migration.",\n    "type": "project",\n    "require": {\n        "php": "^8.2",\n        "laravel/framework": "^11.0",\n        "laravel/telescope": "^5.0",\n        "laravel/compass": "^4.0",\n        "laravel/horizon": "^6.0"\n    },\n    "require-dev": {\n        "phpunit/phpunit": "^10.0"\n    },\n    "autoload": {\n        "psr-4": {\n            "App\\": "app/"\n        }\n    },\n    "autoload-dev": {\n        "psr-4": {\n            "Tests\\": "tests/"\n        }\n    },\n    "scripts": {\n        "post-autoload-dump": [\n            "Illuminate\Foundation\ComposerScripts::postAutoloadDump",\n            "php artisan package:discover --ansi"\n        ]\n    },\n    "minimum-stability": "stable",\n    "prefer-stable": true\n}